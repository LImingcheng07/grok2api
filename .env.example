# Optional environment overrides for local / Compose demos.
# Copy to .env and fill in values. Never commit a real .env.

# Host port for the gateway
# GROK2API_PORT=8000

# Official or self-built image
# GROK2API_IMAGE=ghcr.io/chenyme/grok2api:latest

# Path to runtime config (keep secrets only in this local file)
# GROK2API_CONFIG=./config.yaml

# Auto-register sidecar host port
# AUTO_REGISTER_PORT=8091

TZ=Asia/Shanghai
